/*----------------------------------------------------------------------------*/

void gps_en(_Bool en, uint8_t gps_mode_sel)
{
	if(en == GPS_ON)
	{
		gps_parameter_reset();
		
		HAL_GPIO_WritePin(GPS_EN_GPIO_Port, GPS_EN_Pin, GPIO_PIN_RESET);
		
		HAL_Delay(500);
		
		gps_init(gps_mode_sel);
		
	}
	else if(en == GPS_OFF)
	{
		HAL_GPIO_WritePin(GPS_EN_GPIO_Port, GPS_EN_Pin, GPIO_PIN_SET);
	}
}

